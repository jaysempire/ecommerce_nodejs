<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/login.css">
</head>
<body class="page home-page">

    <%- include('../includes/nav.ejs') %>
    <main class="login-container">
        <section class="login-card">
            <div class="login-header">
                <h2>Create Account</h2>
                <p>Join us today! It only takes a minute.</p>
            </div>

            <% if (errorMessage) { %>
                <div class="user-message user-message--error">
                    <span class="error-icon">⚠️</span> <%= errorMessage %>
                </div>
            <% } %>

            <form action="/signup" method="POST" class="login-form" novalidate>
                <div class="input-group">
                    <label for="email">Email Address</label>
                    <input class="<%= validationErrors.find(e => e.path === 'email') ? 'invalid' : '' %>" type="email" name="email" id="email" placeholder="name@company.com" value="<%= oldInput.email %>" required>
                </div>

                <div class="input-group">
                    <label for="password">Password</label>
                    <input class="<%= validationErrors.find(e => e.path === 'password') ? 'invalid' : '' %>" type="password" name="password" id="password" placeholder="••••••••" value="<%= oldInput.password %>" required>
                </div>

                <div class="input-group">
                    <label for="confirmPassword">Confirm Password</label>
                    <input class="<%= validationErrors.find(e => e.path === 'confirmPassword') ? 'invalid' : '' %>" type="password" name="confirmPassword" id="confirmPassword" placeholder="••••••••" value="<%= oldInput.confirmPassword %>" >
                </div>

                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <button type="submit" class="login-btn">Sign Up</button>
                
                <p class="signup-text">
                    Already have an account? <a href="/login">Login here</a>
                </p>
            </form>
        </section>
    </main>

<%- include('../includes/end.ejs') %>