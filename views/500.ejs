<%- include('includes/head.ejs') %>
</head>
<body class="page error-page">
    <%- include('includes/nav.ejs') %>

    <main class="error-container">
        <div class="error-card">
            <div class="error-visual">
                <span class="error-code">500</span>
                <div class="error-icon">🛠️</div>
            </div>
            <h1>Oops! Something went wrong.</h1>
            <p>Our server encountered an internal error and couldn't complete your request. We've been notified and are working to fix it!</p>
            
            <div class="error-actions">
                <a href="/" class="btn primary">Back to Homepage</a>
                <button onclick="location.reload()" class="btn secondary">Try Again</button>
            </div>
        </div>
    </main>

<%- include('includes/end.ejs') %>