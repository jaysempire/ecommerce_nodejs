<%- include('../includes/head.ejs') %>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body class="page home-page">

    <%- include('../includes/nav.ejs') %>
    <main class="cart-page"> 

        <% if (products.length > 0) { %>
            <h1 class="page-title">Your Cart</h1>
            <p class="page-description">Review items before checkout</p>

            <section class="cart-items">
                <% products.forEach(p => { %>
                    <article class="cart-item">
                        <div class="cart-item__image">
                            <img src="<%= p.productId.imgUrl %>" alt="Product image">
                        </div>

                        <div class="cart-item__details">
                            <h2 class="cart-item__title"><%= p.productId.title %></h2>
                            <p class="cart-item__price">$<%= p.productId.price.toLocaleString('en-US') %></p>
                            <p class="cart-item__qty">Quantity: <%= p.quantity %></p>
                        </div>

                        <div class="cart-item__actions">
                            <form action="/delete-cart-item" method="POST">
                                <input type="hidden" value="<%= p.productId._id %>" name="productId">
                                <button class="btn btn--danger">Remove</button>
                            </form>
                        </div>
                    </article>
                <% }) %>
                
               <section class="cart-summary">
                    <h2>Total: <span>$<%= totalPrice.toLocaleString('en-US') %></span></h2>
                    <!-- <form action="/products" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button class="btn btn--primary">Proceed to Checkout</button>
                    </form> -->
                    <a href="/checkout" class="btn">Proceed to Checkout</a>
                </section>
                
            </section>
            
        <%} else{%>

            <div class="empty-state">
                <div class="icon">🛒</div>
                <h3>Your cart is empty</h3>
                <p>Add some products to see them here.</p>
                <a href="/" class="btn">Start Shopping</a>
            </div>

        <% } %>
    </main>


<%- include('../includes/end.ejs') %>